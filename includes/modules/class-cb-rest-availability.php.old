<?php
namespace Calendly_Bookings\Modules;
if (!defined('ABSPATH')) exit;

class CB_REST_Availability {
    public static function init() {
        add_action('rest_api_init', [__CLASS__, 'register_routes']);
    }

    public static function register_routes() {
        register_rest_route('calendly-bookings/v1', '/availability', [
            'methods'             => 'GET',
            'callback'            => [__CLASS__, 'get_availability'],
            'permission_callback' => '__return_true',
            'args'                => [
                'event_uuid' => [
                    'type'              => 'string',
                    'required'          => false,
                    'sanitize_callback' => 'sanitize_text_field'
                ],
                'product_id' => [
                    'type'              => 'integer',
                    'required'          => false,
                    'sanitize_callback' => 'absint'
                ],
                'date' => [
                    'type'              => 'string',
                    'required'          => false,
                    'sanitize_callback' => 'sanitize_text_field'
                ]
            ]
        ]);
    }

    public static function get_availability(WP_REST_Request $request) {
    $event_uuid = $request->get_param('event_uuid');
    $product_id = $request->get_param('product_id');
    $date       = $request->get_param('date');

    // If no event_uuid but product_id is provided, look up UUID from product meta
    if (empty($event_uuid) && !empty($product_id)) {
        $event_uuid = get_post_meta($product_id, '_cb_event_uuid', true);
    }

    if (empty($event_uuid)) {
        return rest_ensure_response([]); // No UUID found
    }

    // Build Calendly API URL
    $base_url = 'https://api.calendly.com';
    $endpoint = "/event_types/{$event_uuid}/availability";

    // Build query params
    $params = [
        'start_time' => gmdate('c'), // now
        'end_time'   => gmdate('c', strtotime('+30 days')), // next 30 days
    ];
    if (!empty($date)) {
        $params['start_time'] = gmdate('c', strtotime($date . ' 00:00:00'));
        $params['end_time']   = gmdate('c', strtotime($date . ' 23:59:59'));
    }

    $url = add_query_arg($params, $base_url . $endpoint);

    // Get API key from settings (stored securely server-side)
    $api_key = get_option('cb_calendly_api_key');
    if (empty($api_key)) {
        return new \WP_Error('missing_api_key', __('Calendly API key not set', 'calendly-bookings'), ['status' => 500]);
    }

    // Call Calendly API
    $response = wp_remote_get($url, [
        'headers' => [
            'Authorization' => 'Bearer ' . $api_key,
            'Content-Type'  => 'application/json',
        ],
        'timeout' => 15,
    ]);

    if (is_wp_error($response)) {
        return $response;
    }

    $body = json_decode(wp_remote_retrieve_body($response), true);
    if (empty($body['collection'])) {
        return rest_ensure_response([]);
    }

    // Format for <select>
    if (!empty($date)) {
        // Return times for a given date
        $times = array_map(function($slot) {
            $start = strtotime($slot['start_time']);
            return [
                'value' => gmdate('H:i', $start),
                'label' => gmdate('g:i A', $start),
            ];
        }, $body['collection']);
        return rest_ensure_response($times);
    } else {
        // Return unique dates with labels
        $dates = [];
        foreach ($body['collection'] as $slot) {
            $d = gmdate('Y-m-d', strtotime($slot['start_time']));
            if (!isset($dates[$d])) {
                $dates[$d] = [
                    'date'       => $d,
                    'date_label' => gmdate('l, F j, Y', strtotime($slot['start_time'])),
                ];
            }
        }
        return rest_ensure_response(array_values($dates));
    }
}

}